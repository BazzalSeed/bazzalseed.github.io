---
import { BIO_SLIDES } from '../lib/site';
const first = BIO_SLIDES[0];
---
<div data-bioslides class="mt-6">
  <div class="border-l-2 pl-5 min-h-[10rem]" style="border-color: var(--accent)">
    <p data-slide-title class="text-2xl sm:text-3xl font-bold tracking-tight leading-tight" style="color: var(--fg)">{first.title}</p>
    <p data-slide-desc class="mt-3 text-[1.02rem] leading-relaxed max-w-prose" style="color: var(--fg)">{first.desc}</p>
  </div>
  <div class="flex gap-2 mt-5 pl-5">
    {BIO_SLIDES.map((_, idx) => (
      <button
        type="button"
        data-dot={idx}
        aria-label={`Show slide ${idx + 1}`}
        class="h-2 w-2 rounded-full transition-all duration-300 hover:opacity-80"
        style="background: var(--rule)"
      ></button>
    ))}
  </div>
</div>

<script>
  import { BIO_SLIDES } from '../lib/site';
  const root = document.querySelector<HTMLElement>('[data-bioslides]');
  const titleEl = root?.querySelector<HTMLElement>('[data-slide-title]');
  const descEl = root?.querySelector<HTMLElement>('[data-slide-desc]');
  const dots = [...(root?.querySelectorAll<HTMLButtonElement>('[data-dot]') ?? [])];
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (root && titleEl && descEl && BIO_SLIDES.length > 1) {
    const len = BIO_SLIDES.length;
    const durationFor = (t: string) => Math.max(8000, Math.min(15000, t.length * 60));
    let i = 0;
    let timer = 0;
    let remaining = 0;
    let startedAt = 0;
    let paused = false;

    const paint = (n: number) => {
      const s = BIO_SLIDES[n];
      titleEl.textContent = s.title;
      descEl.textContent = s.desc;
      dots.forEach((d, idx) => {
        d.style.background = idx === n ? 'var(--accent)' : 'var(--rule)';
        d.style.width = idx === n ? '1.5rem' : '0.5rem';
      });
      if (!reduce) {
        root.classList.remove('bioslide-anim');
        void root.offsetWidth; // restart entrance animation
        root.classList.add('bioslide-anim');
      }
    };

    const arm = (ms: number) => {
      window.clearTimeout(timer);
      if (reduce) return;
      remaining = ms;
      startedAt = Date.now();
      timer = window.setTimeout(() => go(i + 1), ms);
    };
    const go = (n: number) => {
      i = (n + len) % len;
      paused = false;
      paint(i);
      arm(durationFor(BIO_SLIDES[i].desc));
    };
    const pause = () => {
      if (paused || reduce) return;
      paused = true;
      window.clearTimeout(timer);
      remaining -= Date.now() - startedAt; // keep what's left
    };
    const resume = () => {
      if (!paused || reduce) return;
      paused = false;
      arm(Math.max(1500, remaining)); // resume where we left off
    };

    root.addEventListener('mouseenter', pause);
    root.addEventListener('mouseleave', resume);
    root.addEventListener('focusin', pause);
    root.addEventListener('focusout', resume);
    dots.forEach((d, idx) => d.addEventListener('click', () => go(idx)));

    paint(0);
    arm(durationFor(BIO_SLIDES[0].desc));
  }
</script>
