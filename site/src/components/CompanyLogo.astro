const icon = ICONS[company];
let w = size;
let h = size;
if (icon) {
  const [, , vw, vh] = icon.vb.split(' ').map(Number);
  const box = size * (icon.scale ?? 1);
  const ratio = vw / vh;
  // fit inside box×box by the larger dimension so all marks read the same size
  if (ratio >= 1) { w = box; h = box / ratio; } else { h = box; w = box * ratio; }
  w = Math.round(w);
  h = Math.round(h);
}
---
<span class={`logo-${company} inline-flex items-center justify-center shrink-0`} style="width:40px">
  {icon ? (
    <svg width={w} height={h} viewBox={icon.vb} fill="currentColor" aria-hidden="true" role="img">
      <path d={icon.d} />
    </svg>
  ) : (
    <span class="font-[family-name:var(--mono)] font-bold" style={`font-size:${Math.round(size * 0.7)}px;color:var(--muted)`}>
      {company.charAt(0).toUpperCase()}
    </span>
  )}
</span>
