---
<div class={`flex flex-wrap items-center gap-4 ${cls}`}>
  {SOCIALS.map((s) => (
    <a
      href={s.href}
      aria-label={s.label}
      title={s.label}
      class="hover:opacity-70 transition-opacity"
      style="color: var(--muted)"
      {...(isExternal(s.href) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" role="img">
        {(ICONS[s.label] ?? []).map((d) => <path d={d} />)}
      </svg>
    </a>
  ))}
</div>
