---
import { BIO_LINES } from '../lib/site';
---
<p class="text-[0.95rem] leading-relaxed max-w-prose min-h-[1.6em]" style="color: var(--fg)">
  <span data-typewriter>{BIO_LINES[0]}</span><span class="term-cursor" aria-hidden="true">▮</span>
</p>

<script>
  import { BIO_LINES } from '../lib/site';
  const el = document.querySelector('[data-typewriter]');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (el && !reduce && BIO_LINES.length > 1) {
    let line = 0;
    let ch = BIO_LINES[0].length;
    let deleting = false;
    const tick = () => {
      const text = BIO_LINES[line];
      if (!deleting) {
        ch++;
        el.textContent = text.slice(0, ch);
        if (ch >= text.length) {
          deleting = true;
          setTimeout(tick, 2000);
          return;
        }
      } else {
        ch--;
        el.textContent = text.slice(0, ch);
        if (ch <= 0) {
          deleting = false;
          line = (line + 1) % BIO_LINES.length;
          setTimeout(tick, 350);
          return;
        }
      }
      setTimeout(tick, deleting ? 35 : 55);
    };
    setTimeout(tick, 2000);
  }
</script>
