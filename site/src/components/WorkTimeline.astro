---
import CompanyLogo from './CompanyLogo.astro';

type Role = { title: string; org: string; logo: string; period: string; current?: boolean; notes?: string[] };
const roles: Role[] = [
  { title: 'Senior Staff Software Engineer', org: 'DoorDash', logo: 'doordash', period: 'Jan 2026 — present', current: true,
    notes: [
      'Own the technical direction for DoorDash’s Storage org — the online datastore platform every product team builds on.',
      'Lead a 40-engineer team driving the core initiatives that are redefining the infrastructure layer beneath all of storage.',
      'Accountable for the reliability, performance, and long-term architecture of the datastores behind millions of orders a day.',
    ] },
  { title: 'Staff Software Engineer', org: 'DoorDash', logo: 'doordash', period: 'Jul 2022 — Dec 2025',
    notes: [
      'Drove fleet-wide efficiency and performance gains across DoorDash’s Cassandra deployment (wrote “Cassandra Unleashed”).',
      'Scaled core storage infrastructure to keep pace with the company’s global growth.',
    ] },
  { title: 'Lead Software Engineer', org: 'Meta', logo: 'meta', period: 'Aug 2020 — Oct 2022',
    notes: [
      'Tech lead building services that detect data inconsistencies across Meta’s large distributed systems using novel techniques.',
      'Scaled complex backend services to absorb major traffic spikes.',
      'Mentored engineers and helped them grow.',
    ] },
  { title: 'Senior Software Engineer', org: 'Klaviyo', logo: 'klaviyo', period: 'May 2019 — Aug 2020',
    notes: [
      'Built Abacus 2.0 — a complete overhaul of Klaviyo’s ingestion model, read API, and database schema — running ~10× faster than its predecessor.',
      'Scaled the event pipeline from 500 to 150,000 events/sec (3M DB writes/sec, ~300×), designed to scale horizontally.',
      'Wrote the migration service that moved production data onto the new schema.',
    ] },
  { title: 'Software Engineer · early engineer', org: 'Klaviyo', logo: 'klaviyo', period: 'Apr 2017 — Jul 2019',
    notes: [
      'Built Abacus 1.0 on Apache Flink — the modern streaming service that replaced Klaviyo’s legacy ingestion; processed 1.5B events on Cyber Monday alone.',
      'Built Klaviyo’s first Kafka microservice, now handling billions of events a day.',
      'Maintained core data stores (MySQL, Cassandra, Redis, Memcache) and refactored the legacy pipeline to a clean OOP design.',
    ] },
  { title: 'Backend Software Engineer', org: 'SurveyMini (acq. SMG)', logo: 'surveymini', period: 'Jul 2016 — Mar 2017',
    notes: [
      'Built backend survey-branching logic that renders each next question based on user input.',
      'Improved AWS infrastructure scalability and led a migration from Postgres to DynamoDB.',
    ] },
];

type Education = { title: string; org: string; period: string; honors: string[] };
const education: Education[] = [
  { title: 'B.S. Computer Science', org: 'Washington University in St. Louis', period: '2014 — 2016',
    honors: ['GPA 3.98', 'Summa Cum Laude', 'Tau Beta Pi', 'Brown Fellowship'] },
  { title: 'B.S. Physics', org: 'Denison University', period: '2011 — 2014',
    honors: ['GPA 3.90', 'Summa Cum Laude', 'Sigma Pi Sigma', 'Sigma Xi'] },
];
---
<div>
  {roles.map((r) => (
    <details open={r.current} class="border-b border-[color:var(--rule)]">
      <summary class="flex items-center gap-3 cursor-pointer py-4 select-none">
        <span class="shrink-0 flex items-center" style={`color: var(${r.current ? '--accent' : '--muted'})`}>
          <CompanyLogo company={r.logo} />
        </span>
        <span class="flex-1 min-w-0">
          <span class="text-base font-semibold" style={r.current ? 'color: var(--accent)' : ''}>{r.title}</span>
          <span class="text-sm" style="color: var(--muted)"> · {r.org}</span>
          {r.current && (
            <span class="ml-2 align-middle font-[family-name:var(--mono)] text-[0.6rem] uppercase tracking-wider px-1.5 py-0.5 rounded"
                  style="color: var(--accent); border: 1px solid var(--accent)">now</span>
          )}
        </span>
        <span class="font-[family-name:var(--mono)] text-xs whitespace-nowrap" style="color: var(--muted)">{r.period}</span>
        <span class="chev font-[family-name:var(--mono)] text-sm ml-1" style="color: var(--muted)" aria-hidden="true">›</span>
      </summary>
      {r.notes && (
        <ul class="list-none p-0 pb-4 pl-[34px] m-0">
          {r.notes.map((n) => (
            <li class="text-sm leading-relaxed" style="color: var(--fg)">{n}</li>
          ))}
        </ul>
      )}
    </details>
  ))}

  <h2 class="font-[family-name:var(--mono)] text-xs uppercase tracking-[0.18em] mt-12 mb-4" style="color: var(--accent)">Education</h2>
  {education.map((e) => (
    <div class="py-3 border-b border-[color:var(--rule)]">
      <div class="flex items-baseline justify-between gap-3">
        <span class="text-sm font-medium">{e.title} · <span style="color: var(--muted)">{e.org}</span></span>
        <span class="font-[family-name:var(--mono)] text-xs whitespace-nowrap" style="color: var(--muted)">{e.period}</span>
      </div>
      <div class="flex flex-wrap gap-1.5 mt-2">
        {e.honors.map((h) => (
          <span class="font-[family-name:var(--mono)] text-[0.65rem] px-2 py-0.5 rounded-full"
                style="color: var(--accent); border: 1px solid var(--rule)">{h}</span>
        ))}
      </div>
    </div>
  ))}
</div>
