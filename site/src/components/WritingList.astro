---
import { getCollection } from 'astro:content';
import { sortEntries } from '../lib/writing';
import WritingRow from './WritingRow.astro';
interface Props { limit?: number }
const { limit } = Astro.props;
const all = sortEntries(await getCollection('writing'));
const visible = limit ? all.slice(0, limit) : all;
const rest = limit ? all.slice(limit) : [];
---
<ul class="list-none p-0 m-0">
  {visible.map((e) => <WritingRow entry={e} />)}
</ul>
{rest.length > 0 && (
  <details class="writing-more">
    <summary class="cursor-pointer select-none font-[family-name:var(--mono)] text-sm py-3 hover:opacity-70" style="color: var(--accent)">
      <span class="more-closed">view all writing ({all.length}) →</span>
      <span class="more-open">show less ↑</span>
    </summary>
    <ul class="list-none p-0 m-0">
      {rest.map((e) => <WritingRow entry={e} />)}
    </ul>
  </details>
)}
