---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import WorkTimeline from '../components/WorkTimeline.astro';
import WritingList from '../components/WritingList.astro';
import BioSlides from '../components/BioSlides.astro';
import SocialLinks from '../components/SocialLinks.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { SITE } from '../lib/site';
import profile from '../assets/profile.png';
---
<Base>
  <section class="mt-14">
    <Image
      src={profile}
      alt="Illustrated portrait of Seed Zeng"
      width={192}
      height={192}
      class="w-24 h-24 rounded-full object-cover mb-5 border border-[color:var(--rule)]"
    />
    <h1 class="text-4xl font-bold tracking-tight m-0">{SITE.name}</h1>
    <p class="text-base font-medium mt-2 mb-3" style="color: var(--link)">{SITE.headline}</p>
    <BioSlides />
  </section>

  <section id="work" class="mt-20 scroll-mt-16">
    <SectionLabel name="experience" class="mb-5" />
    <WorkTimeline />
  </section>

  <section id="writing" class="mt-20 scroll-mt-16">
    <SectionLabel name="writing" class="mb-5" />
    <WritingList limit={4} />
  </section>

  <section id="podcast" class="mt-20 scroll-mt-16">
    <SectionLabel name="podcast" class="mb-3" />
    <p class="text-[0.95rem] leading-relaxed max-w-prose mb-5" style="color: var(--muted)">
      <span style="color: var(--fg)">Superposition</span> — examining the world from multiple perspectives, with Seed &amp; Hansen.
    </p>
    <iframe
      title="Superposition podcast"
      loading="lazy"
      src="https://www.podbean.com/player-v2/?i=5vxnc-b09f80-pbblog-playlist&share=1&download=1&rtl=1&fonts=Arial&skin=f6f6f6&font-color=auto&order=episodic&limit=10&filter=all&ss=a713390a017602015775e868a2cf26b0&btn-skin=3267a3&size=358"
      height="358"
      width="100%"
      allowfullscreen
      style="border:1px solid var(--rule); border-radius:10px; min-width: min(100%, 430px);"
    ></iframe>
  </section>

  <section id="contact" class="mt-20 scroll-mt-16">
    <SectionLabel name="contact" title="Get in touch" class="mb-5" />
    <p class="text-[0.95rem] leading-relaxed mb-4" style="color: var(--fg)">Like what you see here? I'm more awesome in person.</p>
    <a
      href="mailto:cdzengpeiyun@gmail.com"
      class="inline-block font-[family-name:var(--mono)] text-sm no-underline rounded px-4 py-2 hover:opacity-70"
      style="border: 1px solid var(--accent); color: var(--accent)"
    >cdzengpeiyun@gmail.com →</a>
    <SocialLinks class="mt-5" />
  </section>
</Base>
