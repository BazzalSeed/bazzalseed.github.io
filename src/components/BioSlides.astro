---
import { getContent } from '../i18n/content';
import { type Locale, DEFAULT_LOCALE, isLocale } from '../i18n/config';
const lang: Locale = isLocale(Astro.currentLocale ?? '') ? (Astro.currentLocale as Locale) : DEFAULT_LOCALE;
const BIO_SLIDES = getContent(lang).bioSlides;
const first = BIO_SLIDES[0];
---
<div data-bioslides data-slides={JSON.stringify(BIO_SLIDES)} class="mt-6">
  <div data-slide-box class="min-h-[10rem]">
    <div data-slide-content class="relative pl-5">
      <span aria-hidden="true" class="absolute left-0 top-0 bottom-0 w-[2px] rounded-full" style="background: var(--rule)"></span>
      <span data-progress aria-hidden="true" class="absolute left-0 top-0 w-[2px] rounded-full" style="background: var(--accent); height: 0%"></span>
      <p data-slide-title class="font-[family-name:var(--mono)] text-2xl sm:text-3xl font-bold tracking-tight leading-tight" style="color: var(--fg)">{first.title}</p>
      <p data-slide-desc class="mt-3 text-[1.02rem] leading-relaxed max-w-prose" style="color: var(--fg)">{first.desc}</p>
    </div>
  </div>
  <div data-bio-controls class="flex items-center gap-3 mt-5 pl-5">
    <div class="flex gap-2">
      {BIO_SLIDES.map((_, idx) => (
        <button
          type="button"
          data-dot={idx}
          aria-label={`Show slide ${idx + 1}`}
          class="h-2 w-2 rounded-full transition-all duration-300 hover:opacity-80 cursor-pointer"
          style="background: var(--rule)"
        ></button>
      ))}
    </div>
    <div class="flex items-center gap-1.5 ml-1 font-[family-name:var(--mono)] leading-none" style="color: var(--accent)">
      <button type="button" data-prev aria-label="Previous slide" class="p-1 text-xl opacity-70 hover:opacity-100 transition-opacity cursor-pointer leading-none">‹</button>
      <button type="button" data-playpause aria-label="Pause" class="p-1 opacity-70 hover:opacity-100 transition-opacity cursor-pointer inline-flex items-center">
        <svg class="pp-pause w-3 h-3" viewBox="0 0 8 10" fill="currentColor" aria-hidden="true"><rect width="3" height="10" rx="1"></rect><rect x="5" width="3" height="10" rx="1"></rect></svg>
        <svg class="pp-play hidden w-3 h-3" viewBox="0 0 10 12" fill="currentColor" aria-hidden="true"><path d="M1 0.8 L9 6 L1 11.2 Z"></path></svg>
      </button>
      <button type="button" data-next aria-label="Next slide" class="p-1 text-xl opacity-70 hover:opacity-100 transition-opacity cursor-pointer leading-none">›</button>
    </div>
  </div>
</div>

<script>
  const root = document.querySelector<HTMLElement>('[data-bioslides]');
  const BIO_SLIDES = JSON.parse(root?.dataset.slides ?? '[]') as { title: string; desc: string }[];
  const titleEl = root?.querySelector<HTMLElement>('[data-slide-title]');
  const descEl = root?.querySelector<HTMLElement>('[data-slide-desc]');
  const dots = [...(root?.querySelectorAll<HTMLButtonElement>('[data-dot]') ?? [])];
  const fill = root?.querySelector<HTMLElement>('[data-progress]');
  const prevBtn = root?.querySelector<HTMLButtonElement>('[data-prev]');
  const nextBtn = root?.querySelector<HTMLButtonElement>('[data-next]');
  const box = root?.querySelector<HTMLElement>('[data-slide-box]');
  const content = root?.querySelector<HTMLElement>('[data-slide-content]');
  const ppBtn = root?.querySelector<HTMLButtonElement>('[data-playpause]');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (root && titleEl && descEl && BIO_SLIDES.length > 1) {
    const len = BIO_SLIDES.length;
    // Longer dwell: ~3s baseline bump on top of a content-length scale.
    const durationFor = (t: string) => Math.max(7000, Math.min(12000, t.length * 45 + 1000));
    let i = 0;
    let timer = 0;
    let remaining = 0;
    let startedAt = 0;
    let paused = false;
    let userPaused = false; // sticky pause from the play/pause button

    const paint = (n: number) => {
      const s = BIO_SLIDES[n];
      titleEl.textContent = s.title;
      descEl.textContent = s.desc;
      dots.forEach((d, idx) => {
        d.style.background = idx === n ? 'var(--accent)' : 'var(--rule)';
        d.style.width = idx === n ? '1.5rem' : '0.5rem';
      });
      if (!reduce) {
        root.classList.remove('bioslide-anim');
        void root.offsetWidth; // restart entrance animation
        root.classList.add('bioslide-anim');
      }
    };

    const arm = (ms: number) => {
      window.clearTimeout(timer);
      if (reduce) return;
      remaining = ms;
      startedAt = Date.now();
      timer = window.setTimeout(() => go(i + 1), ms);
    };

    // The left quote line doubles as a progress bar (fills over the slide, freezes on hover).
    const fillTo = (ms: number) => {
      if (!fill || reduce) return;
      fill.style.transition = 'none';
      fill.style.height = '0%';
      void fill.offsetWidth;
      fill.style.transition = `height ${ms}ms linear`;
      fill.style.height = '100%';
    };
    const fillPause = () => {
      if (!fill || reduce) return;
      const ph = fill.parentElement ? parseFloat(getComputedStyle(fill.parentElement).height) : 0;
      const cur = parseFloat(getComputedStyle(fill).height);
      fill.style.transition = 'none';
      fill.style.height = ph ? `${(cur / ph) * 100}%` : '0%';
      void fill.offsetWidth;
    };
    const fillResume = (ms: number) => {
      if (!fill || reduce) return;
      fill.style.transition = `height ${ms}ms linear`;
      fill.style.height = '100%';
    };

    const go = (n: number) => {
      i = (n + len) % len;
      paint(i);
      if (userPaused) {
        // navigate only — stay paused, reset progress to empty
        window.clearTimeout(timer);
        remaining = durationFor(BIO_SLIDES[i].desc);
        if (fill && !reduce) { fill.style.transition = 'none'; fill.style.height = '0%'; void fill.offsetWidth; }
        return;
      }
      paused = false;
      const d = durationFor(BIO_SLIDES[i].desc);
      arm(d);
      fillTo(d);
    };
    const pause = () => {
      if (paused || reduce) return;
      paused = true;
      window.clearTimeout(timer);
      remaining -= Date.now() - startedAt;
      fillPause();
    };
    const resume = () => {
      if (!paused || reduce) return;
      paused = false;
      const r = Math.max(1200, remaining);
      arm(r);
      fillResume(r);
    };

    // Pause-on-hover only on hover-capable (desktop) devices — touch fakes
    // mouse events and would get stuck paused / stutter.
    // Hover-pause only on hover-capable (desktop) devices; the play/pause button
    // covers touch. A sticky user-pause is never auto-resumed by hover.
    if (matchMedia('(hover: hover)').matches) {
      root.addEventListener('mouseenter', () => { if (!userPaused) pause(); });
      root.addEventListener('mouseleave', () => { if (!userPaused) resume(); });
      root.addEventListener('focusin', () => { if (!userPaused) pause(); });
      root.addEventListener('focusout', () => { if (!userPaused) resume(); });
    }
    dots.forEach((d, idx) => d.addEventListener('click', () => go(idx)));
    prevBtn?.addEventListener('click', () => go(i - 1));
    nextBtn?.addEventListener('click', () => go(i + 1));

    const ppPause = ppBtn?.querySelector<SVGElement>('.pp-pause');
    const ppPlay = ppBtn?.querySelector<SVGElement>('.pp-play');
    const setPP = () => {
      if (!ppBtn) return;
      ppBtn.setAttribute('aria-label', userPaused ? 'Play' : 'Pause');
      ppPause?.classList.toggle('hidden', userPaused);
      ppPlay?.classList.toggle('hidden', !userPaused);
    };
    ppBtn?.addEventListener('click', () => {
      userPaused = !userPaused;
      if (userPaused) pause(); else resume();
      setPP();
    });

    // Lock the slide box to the tallest slide's height (at the current width) so
    // auto-rotation never reflows the page (no stutter, esp. on mobile).
    const fitHeight = () => {
      if (!box || !content) return;
      const cur = i;
      box.style.height = 'auto';
      let max = 0;
      for (let n = 0; n < len; n++) {
        titleEl.textContent = BIO_SLIDES[n].title;
        descEl.textContent = BIO_SLIDES[n].desc;
        if (content.offsetHeight > max) max = content.offsetHeight;
      }
      titleEl.textContent = BIO_SLIDES[cur].title;
      descEl.textContent = BIO_SLIDES[cur].desc;
      box.style.height = `${max}px`;
    };

    const startAll = () => {
      paint(0);
      fitHeight();
      if (reduce) {
        if (fill) fill.style.height = '100%';
      } else {
        const d0 = durationFor(BIO_SLIDES[0].desc);
        arm(d0);
        fillTo(d0);
      }
    };
    (document.fonts ? document.fonts.ready : Promise.resolve()).then(startAll);

    let resizeT = 0;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeT);
      resizeT = window.setTimeout(fitHeight, 150);
    });
  }
</script>
