---
import { SITE } from '../lib/site';
import { Image } from 'astro:assets';
import profile from '../assets/profile.png';
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';
import SocialLinks from './SocialLinks.astro';
import { t } from '../i18n/ui';
import { type Locale, DEFAULT_LOCALE, isLocale } from '../i18n/config';
const lang: Locale = isLocale(Astro.currentLocale ?? '') ? (Astro.currentLocale as Locale) : DEFAULT_LOCALE;
const home = lang === 'en' ? '/' : '/zh';
const NAV = [
  { href: `${home}#work`, label: t(lang, 'nav.work') },
  { href: `${home}#writing`, label: t(lang, 'nav.writing') },
  { href: `${home}#podcast`, label: t(lang, 'nav.podcast') },
  { href: `${home}#contact`, label: t(lang, 'nav.contact') },
];
---
<div class="flex flex-col gap-6">
  <a href={home} class="no-underline w-fit">
    <Image src={profile} alt="Seed Zeng" width={144} height={144}
      class="w-16 h-16 rounded-full object-cover border border-[color:var(--rule)]" />
  </a>
  <a href={home} class="lnk font-[family-name:var(--mono)] text-base font-bold w-fit">
    ~/{SITE.wordmark}<span class="term-cursor" aria-hidden="true">▮</span>
  </a>
  <nav class="flex flex-col gap-2.5 font-[family-name:var(--sans)] font-medium text-sm">
    {NAV.map((item) => (
      <a href={item.href} class="lnk w-fit">{item.label}</a>
    ))}
  </nav>
  <span class="inline-flex w-fit items-center gap-2.5 rounded-full border border-[color:var(--rule)] px-3 py-1">
    <LanguageToggle />
    <span class="text-[color:var(--muted)] opacity-40 text-xs leading-none" aria-hidden="true">·</span>
    <ThemeToggle />
  </span>
  <SocialLinks />
</div>
