---
import CompanyLogo from './CompanyLogo.astro';
import EduLogo from './EduLogo.astro';
import SectionLabel from './SectionLabel.astro';
import { getContent } from '../i18n/content';
import { t } from '../i18n/ui';
import { type Locale, DEFAULT_LOCALE, isLocale } from '../i18n/config';
const lang: Locale = isLocale(Astro.currentLocale ?? '') ? (Astro.currentLocale as Locale) : DEFAULT_LOCALE;
const { roles, education } = getContent(lang);
---
<div>
  <div class="flex items-center gap-2 mb-3">
    <button type="button" data-roles-toggle aria-expanded="false"
      class="ra-toggle font-[family-name:var(--mono)] text-xs bg-transparent border-0 p-0 cursor-pointer hover:opacity-70" style="color: var(--muted)">
      <span class="ra-closed">{t(lang, 'roles.expandAll')}</span><span class="ra-open">{t(lang, 'roles.collapseAll')}</span>
    </button>
    <span class="ra-hint font-[family-name:var(--mono)] text-[0.68rem]" style="color: var(--muted); opacity: 0.7">{t(lang, 'roles.hint')}</span>
  </div>
  {roles.map((r) => (
    <details open={r.current} class="role">
      <summary class="cursor-pointer py-4 select-none">
        <div class="flex items-center gap-3">
          <CompanyLogo company={r.logo} />
          <span class="flex-1 min-w-0">
            <span class="role-title text-base font-semibold">{r.title}</span>
            <span class="text-sm" style="color: var(--muted)"> · {r.org}</span>
          </span>
          <span class="font-[family-name:var(--mono)] text-xs whitespace-nowrap" style="color: var(--muted)">
            {r.current
              ? (<>{r.period.split(' — ')[0]} — <span style="color: var(--accent)">{r.period.split(' — ')[1]}</span></>)
              : r.period}
          </span>
          <svg class="chev ml-1 shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent)" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
        </div>
        <p class="text-[0.95rem] leading-relaxed mt-2 pl-[52px]" style="color: var(--fg)">{r.summary}</p>
      </summary>
      <div class="pb-5 pl-[52px]">
        <ul class="list-none p-0 m-0 space-y-1.5">
          {r.notes.map((n) => (
            <li class="text-sm leading-relaxed flex gap-2" style="color: var(--fg)">
              <span aria-hidden="true" style="color: var(--accent)">–</span><span>{n}</span>
            </li>
          ))}
        </ul>
      </div>
    </details>
  ))}

  <SectionLabel name="education" title={t(lang, 'section.education')} class="mt-12 mb-4" />
  <div class="flex items-center gap-2 mb-3">
    <button type="button" data-edu-toggle aria-expanded="false"
      class="ra-toggle font-[family-name:var(--mono)] text-xs bg-transparent border-0 p-0 cursor-pointer hover:opacity-70" style="color: var(--muted)">
      <span class="ra-closed">{t(lang, 'roles.expandAll')}</span><span class="ra-open">{t(lang, 'roles.collapseAll')}</span>
    </button>
    <span class="ra-hint font-[family-name:var(--mono)] text-[0.68rem]" style="color: var(--muted); opacity: 0.7">{t(lang, 'roles.hint')}</span>
  </div>
  {education.map((e) => (
    <details class="role edu">
      <summary class="cursor-pointer py-4 select-none">
        <div class="flex items-center gap-3">
          <EduLogo logo={e.logo} class="shrink-0" />
          <span class="role-title text-base font-semibold flex-1 min-w-0">{e.school}</span>
          <span class="font-[family-name:var(--mono)] text-xs whitespace-nowrap" style="color: var(--muted)">{e.period}</span>
          <svg class="chev ml-1 shrink-0" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent)" aria-hidden="true"><path d="M6 9l6 6 6-6"></path></svg>
        </div>
        <p class="font-[family-name:var(--mono)] text-xs mt-1 pl-[52px]" style="color: var(--muted)">{e.degree} · {e.gpa}</p>
        <p class="text-[0.95rem] leading-relaxed mt-2 pl-[52px]" style="color: var(--fg)">{e.summary}</p>
      </summary>
      <div class="pb-5 pl-[52px]">
        <ul class="list-none p-0 m-0 space-y-1.5">
          {e.notes.map((n) => (
            <li class="text-sm leading-relaxed flex gap-2" style="color: var(--fg)">
              <span aria-hidden="true" style="color: var(--accent)">–</span><span>{n}</span>
            </li>
          ))}
        </ul>
      </div>
    </details>
  ))}
</div>

<script>
  const wire = (btn: HTMLButtonElement | null, selector: string) => {
    btn?.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') !== 'true';
      document.querySelectorAll(selector).forEach((d) => ((d as HTMLDetailsElement).open = open));
      btn.setAttribute('aria-expanded', String(open));
    });
  };
  wire(document.querySelector<HTMLButtonElement>('[data-roles-toggle]'), 'details.role:not(.edu)');
  wire(document.querySelector<HTMLButtonElement>('[data-edu-toggle]'), 'details.role.edu');
</script>
