---
import type { CollectionEntry } from 'astro:content';
import { entryHref } from '../lib/writing';
interface Props { entry: CollectionEntry<'writing'>; class?: string }
const { entry, class: cls = '' } = Astro.props;
const href = entryHref(entry);
const year = entry.data.date.getFullYear();
const external = entry.data.external;
---
<li class={`border-b border-[color:var(--rule)] ${cls}`}>
  <a
    href={href}
    class="lnk flex items-baseline justify-between gap-3 py-2"
    {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
  >
    <span class="min-w-0">
      <span class="font-[family-name:var(--mono)] text-xs opacity-60 mr-3">{year}</span>{entry.data.title}
    </span>
    <span class="font-[family-name:var(--mono)] text-xs whitespace-nowrap shrink-0"
          style={`color: var(${external ? '--link' : '--post'})`}>
      {external ? `${entry.data.source ?? 'link'} ↗` : '● post'}
    </span>
  </a>
</li>
