---
import '@fontsource-variable/jetbrains-mono';
import '@fontsource-variable/inter';
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { type Locale, DEFAULT_LOCALE, isLocale } from '../i18n/config';
interface Props { title?: string; description?: string; }
const { title, description } = Astro.props;
const lang: Locale = isLocale(Astro.currentLocale ?? '') ? (Astro.currentLocale as Locale) : DEFAULT_LOCALE;
---
<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <BaseHead title={title} description={description} />
    <script is:inline>
      // Theme follows the OS on every load (no persistence). A manual toggle is
      // an in-memory override that a reload or OS change discards.
      document.documentElement.dataset.theme =
        matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    </script>
    <script is:inline>
      // Language mirrors the theme model: the browser language drives every load
      // (a zh browser sees /zh, otherwise English). A manual switch is a one-shot
      // override — consumed on arrival, never persisted — so it shows the chosen
      // language for that switch, and any refresh re-inherits the system language.
      (function () {
        try {
          var override = sessionStorage.getItem('langOverride');
          if (override) sessionStorage.removeItem('langOverride'); // one-shot: consume immediately
          var path = location.pathname;
          var onZh = path === '/zh' || path.indexOf('/zh/') === 0;
          if (override === 'en' || override === 'zh') return; // honor the switch; URL is already correct
          // No override → follow the system language on every load.
          var sysZh = (navigator.language || '').toLowerCase().indexOf('zh') === 0;
          if (sysZh && !onZh) { location.replace('/zh' + (path === '/' ? '' : path)); return; }
          if (!sysZh && onZh) { location.replace(path.replace(/^\/zh/, '') || '/'); return; }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header data-header class="sticky top-0 z-50 min-[1440px]:hidden">
      <div class="mx-auto max-w-2xl px-6">
        <Nav />
      </div>
    </header>
    <script is:inline>
      (function () {
        var h = document.querySelector('[data-header]');
        if (!h) return;
        var sync = function () { h.toggleAttribute('data-scrolled', window.scrollY > 4); };
        sync();
        window.addEventListener('scroll', sync, { passive: true });
      })();
    </script>
    <div class="mx-auto px-6 max-w-2xl min-[1440px]:max-w-none min-[1440px]:w-fit min-[1440px]:grid min-[1440px]:grid-cols-[200px_672px] min-[1440px]:gap-20">
      <!-- left rail: ultra-wide only -->
      <aside class="hidden min-[1440px]:block">
        <div class="min-[1440px]:sticky min-[1440px]:top-0 min-[1440px]:max-h-screen min-[1440px]:overflow-y-auto py-12">
          <Sidebar />
        </div>
      </aside>
      <div class="pb-12 min-[1440px]:py-12">
        <main>
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
